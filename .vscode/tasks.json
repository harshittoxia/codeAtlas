{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch:esbuild",
      "type": "npm",
      "script": "watch:esbuild",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      }
    }
  ]
}
